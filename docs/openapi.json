    "/api/v1/screener": {
      "get": {
        "tags": [
          "Screener"
        ],
        "summary": "Execute quantitative stock screener query",
        "description": "Execute quantitative stock screening query across financial metrics.\n\nReturns:\n- Total matching companies\n- Filters applied\n- Sorted results with ranks and latest financial KPIs",
        "operationId": "run_screener_query_api_v1_screener_get",
        "parameters": [
          {
            "name": "min_roe",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "number"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Minimum ROE percentage threshold",
              "title": "Min Roe"
            },
            "description": "Minimum ROE percentage threshold"
          },
          {
            "name": "max_de",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "number"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Maximum Debt-to-Equity threshold",
              "title": "Max De"
            },
            "description": "Maximum Debt-to-Equity threshold"
          },
          {
            "name": "min_fcf",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "number"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Minimum Free Cash Flow (in Crores)",
              "title": "Min Fcf"
            },
            "description": "Minimum Free Cash Flow (in Crores)"
          },
          {
            "name": "sector",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Filter by broad sector name",
              "title": "Sector"
            },
            "description": "Filter by broad sector name"
          },
          {
            "name": "min_rev_cagr_5yr",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "number"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Minimum 5-Year Revenue CAGR percentage",
              "title": "Min Rev Cagr 5Yr"
            },
            "description": "Minimum 5-Year Revenue CAGR percentage"
          },
          {
            "name": "min_pat_cagr_5yr",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "number"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Minimum 5-Year PAT CAGR percentage",
              "title": "Min Pat Cagr 5Yr"
            },
            "description": "Minimum 5-Year PAT CAGR percentage"
          },
          {
            "name": "max_pe",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "number"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Maximum Price-to-Earnings ratio threshold",
              "title": "Max Pe"
            },
            "description": "Maximum Price-to-Earnings ratio threshold"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScreenerResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
